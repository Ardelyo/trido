# AI Configuration
# Modes: 'gemini' (cloud) or 'ollama' (local)
AI_MODE=gemini

# Local Model (Ollama)
# Suggested: 'gemma4:e2b' (High accuracy, 7.2GB RAM)
# Suggested: 'gemma:2b' (Fast, 1.7GB RAM - use for 8GB total RAM devices)
OLLAMA_MODEL=gemma4:e2b

# Connection
OLLAMA_BASE_URL=http://localhost:11434

# Features
OLLAMA_THINKING_MODE=nothink

# Cloud API (Gemini / Custom Provider)
# Masukkan kunci API Anda di sini untuk mode 'gemini'
