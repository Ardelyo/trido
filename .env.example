# AI Mode: 'auto' | 'gemini' | 'ollama' | 'vertex'
AI_MODE=auto

# ── Google Gemini / Gemma 4 (cloud) ─────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/apikey
# This key stays SERVER-SIDE ONLY. Never put it in frontend code.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Ollama (local / offline) ─────────────────────────────────────────────────
# Install Ollama: https://ollama.ai
# Pull model: ollama pull gemma4:e2b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_THINKING_MODE=nothink
# OLLAMA_API_KEY=        # Only needed if your Ollama has auth enabled

# ── Vertex AI (optional, Google Cloud) ───────────────────────────────────────
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# VERTEX_LOCATION=us-central1

# ── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=3000
NODE_ENV=development

# ── Production deployment ─────────────────────────────────────────────────────
# Set ALLOWED_ORIGIN to your domain when deploying live.
# Example: ALLOWED_ORIGIN=https://trido.vercel.app
# If not set, Socket.IO uses '*' in development and blocks all in production.
# ALLOWED_ORIGIN=https://your-domain.com

# ── Session persistence ───────────────────────────────────────────────────────
# Path to the JSON file used to persist canvas rooms across server restarts.
# On ephemeral hosts (Render, Railway) this resets on each deploy.
# Point to a persistent volume path to retain sessions across deploys.
# ROOMS_FILE_PATH=/data/rooms_persistence.json
